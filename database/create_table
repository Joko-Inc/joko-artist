-- SQLite — Artist table (base)
-- Full schema + ER diagram: see SCHEMA.md in this folder
CREATE TABLE IF NOT EXISTS Artist (
    id              TEXT PRIMARY KEY DEFAULT (lower(hex(randomblob(16)))),
    name            TEXT NOT NULL,
    profile_pic_url TEXT,

    avg_sub_amount  REAL NOT NULL DEFAULT 0.0,
    engagement      REAL NOT NULL DEFAULT 0.0,
    total_views     INTEGER NOT NULL DEFAULT 0,
    monthly_revenue REAL NOT NULL DEFAULT 0.0,

    username        TEXT,
    password_hash   TEXT,

    -- auth / onboarding (migrate_onboarding_profile, migrate_artist_auth)
    email                   TEXT,
    email_verified          TEXT,
    verification_token      TEXT,
    password_reset_token    TEXT,
    password_reset_expires  TEXT,
    first_name              TEXT,
    last_name               TEXT,
    artist_name             TEXT,
    slug                    TEXT,
    location                TEXT,
    phone                   TEXT,
    artist_statement        TEXT,
    website                 TEXT,
    instagram               TEXT,
    twitter                 TEXT,
    music_links             TEXT,
    other_links             TEXT,
    aesthetic_urls          TEXT,

    -- monetization / Circle (migrate_wallet_columns)
    circle_wallet_id  TEXT,
    wallet_address    TEXT,
    wallet_chain      TEXT,

    created_at      TEXT NOT NULL DEFAULT (datetime('now')),
    updated_at      TEXT NOT NULL DEFAULT (datetime('now'))
);

CREATE UNIQUE INDEX IF NOT EXISTS idx_artist_username ON Artist(username);
