# Server
JWT_SECRET=change-me-in-production
APP_URL=http://localhost:5173

# Payments service (Joko-Payments-Infrastructure backend)
PAYMENTS_URL=http://localhost:5001

# Circle wallet auto-provisioning on artist signup
# Get ARTIST_WALLET_SET_ID from payments backend storage/wallets.json ("Artist Set" key)
# or create one via POST /joko/wallet/wallet-set { "name": "Artist Set" }
ARTIST_WALLET_SET_ID=
ARTIST_WALLET_BLOCKCHAINS=SOL-DEVNET

# USDC token ID for withdrawals (from Circle dashboard)
USDC_TOKEN_ID=

# Email verification (optional — without these, links are logged to the server console)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=Joko <noreply@yourdomain.com>
