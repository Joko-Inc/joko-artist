# =============================================================================
# joko-artist — copy to .env and fill in (never commit .env)
# cp .env.example .env
# =============================================================================

# ── Core server ───────────────────────────────────────────────────────────────
# Used to sign login JWTs. Use a long random string in production.
JWT_SECRET=change-me-in-production

# Base URL for email links (verification + password reset).
# MUST match the Vite dev port — vite.config.ts uses port 5173 with strictPort.
APP_URL=http://localhost:5173

# Optional on Render / production:
# DATA_DIR=/data
# UPLOADS_DIR=/data/uploads

# ── Email — signup verification & forgot password (Resend recommended) ────────
# If SMTP_* is missing, links are printed in the npm run server terminal instead.
#
# Resend setup:
#   1. Create account at https://resend.com
#   2. API Keys → Create API Key → paste as SMTP_PASS
#   3. Use defaults below for SMTP_HOST/USER/PORT
#   4. Until you verify a domain, SMTP_FROM must be onboarding@resend.dev and
#      emails only deliver to the address on your Resend account
#   5. After domain verification, change SMTP_FROM to e.g. Joko <onboarding@yourdomain.com>
#
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=Joko <onboarding@resend.dev>

# ── Monetization / Circle wallets (requires payments backend on :5001) ─────────
# Step 1 — Start payments backend (separate folder):
#   cd ../Joko-Payments-Infrastructure-and-Smartcontracts/backend
#   cp .env.example .env
#   # Set CIRCLE_API_KEY, CIRCLE_ENTITY_SECRET, PORT=5001
#   npm run dev
#
# Step 2 — Create wallet set (once, with backend running):
#   curl -X POST http://localhost:5001/joko/wallet/wallet-set \
#     -H "Content-Type: application/json" \
#     -d '{"name": "Artist Set"}'
#   Copy walletSetId → ARTIST_WALLET_SET_ID below
#   (also saved in backend/storage/wallets.json under "Artist Set")
#
PAYMENTS_URL=http://localhost:5001
ARTIST_WALLET_SET_ID=
ARTIST_WALLET_BLOCKCHAINS=SOL-DEVNET
#
# Circle Token ID for USDC withdrawals — NOT the Solana mint address.
# After an artist creates a wallet, find it via:
#   GET http://localhost:5001/joko/wallet/balance/<circleWalletId>
#   → tokenBalances[].token.id where name is "USD Coin"
# Devnet example: 8fb3cadb-0ef4-573d-8fcd-e194f961c728
USDC_TOKEN_ID=

# ── Example: full local devnet .env (replace IDs with yours) ─────────────────
# JWT_SECRET=local-dev-secret
# APP_URL=http://localhost:5173
# PAYMENTS_URL=http://localhost:5001
# ARTIST_WALLET_SET_ID=342c6f15-a709-5dc8-891e-68b5715d7085
# ARTIST_WALLET_BLOCKCHAINS=SOL-DEVNET
# USDC_TOKEN_ID=8fb3cadb-0ef4-573d-8fcd-e194f961c728
# SMTP_PASS=re_your_resend_api_key

# ── Payments backend .env (NOT this file — backend/.env) ─────────────────────
# CIRCLE_API_KEY=...
# CIRCLE_ENTITY_SECRET=...   # or run backend/register-entity-secret.ts once
# PORT=5001
# Do NOT commit backend/recovery/ (Circle recovery files)
